# Copy this file to /etc/pi4-tree-ai.env on the Pi and edit values as needed.

DEVICE_ID=tomato_001
FIREBASE_DB_URL=https://pi4-iot-1b7bb-default-rtdb.asia-southeast1.firebasedatabase.app
GOOGLE_APPLICATION_CREDENTIALS=/home/khanhpi/project/pi4_treeai/firebase_key.json
SERVER_URL=http://192.168.1.100:5000
CONF=0.5

WIDTH=640
HEIGHT=480
CAMERA_BACKEND=opencv
CAMERA_INDEX=0

COMMAND_POLL_INTERVAL=1.0
ENABLE_SHARPEN=false
SHARPEN_AMOUNT=0.2
JPEG_QUALITY=95
ENABLE_COLOR_CORRECTION=true
AUTO_WHITE_BALANCE=true
GAMMA=1.15
SATURATION_GAIN=1.05

SAVE_SNAPSHOTS=true
SNAPSHOT_DIR=detections/snapshots
VERBOSE=true

# Sensor publish (LM393 DO + DHT11/DHT22)
SENSOR_PUBLISH_ENABLED=true
SENSOR_PUBLISH_INTERVAL=15
SENSOR_PATH_TEMPLATE=plant/{device_id}/sensor

# Sensor source: local, uart, or ble
SENSOR_SOURCE=uart
UART_SERIAL_PORT=/dev/serial0
UART_BAUDRATE=115200
UART_SERIAL_TIMEOUT=0.05
UART_STALE_AFTER=30
UART_ERROR_STREAK_THRESHOLD=2

# BLE sensor source (ESP32 as peripheral)
BLE_DEVICE_NAME=
BLE_ADDRESS=
BLE_SERVICE_UUID=
BLE_NOTIFY_CHAR_UUID=
BLE_SCAN_TIMEOUT=6
BLE_CONNECT_TIMEOUT=10
BLE_RECONNECT_DELAY=3
BLE_STALE_AFTER=30
BLE_ERROR_STREAK_THRESHOLD=2

# OLED status display (SSD1306 I2C 128x64)
OLED_ENABLED=false
OLED_I2C_ADDRESS=60
OLED_WIDTH=128
OLED_HEIGHT=64
OLED_ROTATE=0
OLED_UPDATE_INTERVAL=2
OLED_WIFI_REFRESH_INTERVAL=10

# Soil moisture module LM393 (DO)
SOIL_SENSOR_GPIO=17
SOIL_SENSOR_ACTIVE_LOW=true
SOIL_SENSOR_PULL=up
SOIL_SENSOR_SAMPLE_COUNT=15
SOIL_SENSOR_SAMPLE_DELAY=0.02

# DHT sensor
DHT_SENSOR_TYPE=DHT11
DHT_SENSOR_GPIO=4
